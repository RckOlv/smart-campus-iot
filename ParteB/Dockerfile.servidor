# Build stage
FROM golang:1.22-alpine AS builder
ENV GOTOOLCHAIN=auto
WORKDIR /app
COPY go.mod go.sum* ./
RUN go mod download 2>/dev/null || true
COPY . .
RUN go build -o /servidor ./cmd/servidor

# Runtime stage
FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /root/
COPY --from=builder /servidor .
ENV RPC_PUERTO=:1234
ENV HEARTBEAT_PUERTO=:4001
ENV HEARTBEAT_DESTINO=""
ENV NODO_ID=servidor-1
EXPOSE 1234 4001/udp
CMD ["./servidor"]
